SECURE PROGRAM

#include <iostream>
using namespace std;
int main(){
	int role;
	
	cout << "enter role (1=admin, 2=user): ";
	cin >> role;
	
	if(role==1){
		cout<<"admin privilege granted." <<endl;
	}
	else{
		cout<<"access denied." <<endl;
	}
	return 0;
}


